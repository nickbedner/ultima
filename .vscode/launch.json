{
  // Note: These are for when launched with c/cpp tools
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch VS",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
        "../src/hello.ult"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "console": "integratedTerminal"
    },
    {
      "name": "Launch LLVM",
      "type": "lldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
        "../src/hello.ult"
      ],
      "cwd": "${workspaceFolder}/build",
      "console": "integratedTerminal"
    }
  ]
}