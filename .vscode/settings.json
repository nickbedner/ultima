        "shader.h": "c",
        "graphicsutils.h": "c",
        "stdbool.h": "c",
        "engine.h": "c",
        "deque": "c",
        "stack": "c",
        "chaos.h": "c",
        "texture.h": "c",
        "stb_image.h": "c",
        "mesh.h": "c",
        "model.h": "c",
        "mana.h": "c",
        "common.h": "c",
        "stdio.h": "c",
        "cglm.h": "c",
        "stdlib.h": "c",
        "string.h": "c",
        "thread.h": "c",
        "threads.h": "c",
        "datastructures.h": "c",
        "vulkan.h": "c",
        "arraylist.h": "c",
        "direct.h": "c",
        "corecrt.h": "c",
        "vcruntime.h": "c",
        "vadefs.h": "c",
        "corecrt_wtime.h": "c",
        "windows.h": "c",
        "winapifamily.h": "c",
        "noise.h": "c",
        "vec3.h": "c",
        "array": "c",
        "vector": "c",
        "fstream": "c",
        "random": "c",
        "regex": "c",
        "chrono": "c",
        "locale": "c",
        "cstdlib": "c",
        "thread": "c",
        "bitset": "c",
        "codecvt": "c",
        "filesystem": "c",
        "memory": "c",
        "limits": "c",
        "*.asm": "c",
    },
    // Note: This is when launched with cmake
    "cmake.debugConfig": {
        "name": "Launch",
        "type": "cppvsdbg",
        "request": "launch",
        "cwd": "${workspaceFolder}/build",
        "console": "integratedTerminal",
        "args": [
            "../src/hello.ult"
        ]
    },
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.buildBeforeRun": true,
    "C_Cpp.default.cStandard": "c23",
    "C_Cpp.default.cppStandard": "c++23",
    "C_Cpp.loggingLevel": "Debug",
    "C_Cpp.default.intelliSenseMode": "windows-clang-x64",
    "cmake.options.advanced": {
        "cpack": {
            "statusBarVisibility": "hidden"
        },
        "workflow": {
            "statusBarVisibility": "hidden"
        }
    }
}